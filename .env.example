# Copy to .env and fill in your OpenAI key. Used for the LLM-assisted tailoring/letter steps.
# .env is gitignored.

# --- LLM provider (OpenAI-compatible) ---
# Default is OpenAI: paste your key below.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
# No OpenAI key? Point at any OpenAI-COMPATIBLE free provider by changing the three lines above.
# Example — Groq free tier (no credit card; get a key at https://console.groq.com):
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_API_KEY=<your-groq-key>
#   OPENAI_MODEL=llama-3.3-70b-versatile

# --- Optional: job-source credentials for find_offers.py adapters ---
# JOB_SOURCE_API_KEY=

# Optional URL extraction helper for JS-heavy or blocked job pages.
FIRECRAWL_API_KEY=

# France Travail API (Offres d'emploi v2)
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
